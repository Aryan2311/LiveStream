project_id   = "your-gcp-project-id"
region       = "us-central1"
zone         = "us-central1-a"
name         = "live-demo"
machine_type = "e2-standard-4"
image_tag    = "latest"

# Restrict SSH to your IP for better security, e.g. ["203.0.113.10/32"]
ssh_source_ranges = ["0.0.0.0/0"]

# Optional: custom domain via Cloudflare (see deploy/gcp/CLOUDFLARE.md)
# custom_domain = "live.example.com"
# cloudflare_origin_cert_file = "cloudflare-origin.pem"
# cloudflare_origin_key_file  = "cloudflare-origin-key.pem"
